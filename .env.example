# ======================================================================
# Pixelyf 오픈소스 프로젝트 환경 변수 템플릿 (.env.example)
# ======================================================================
# 아래 변수들을 실제 서비스 환경에 맞게 기입한 뒤 파일명을 .env 로 변경하여 사용하십시오.

# 1. Prisma 및 Database 연결 설정 (필수)
# Connection Pooling이 지원되는 PostgreSQL 연결 주소 (예: Supabase Transaction URL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# 스키마 마이그레이션 등을 위해 사용하는 Direct DB 연결 주소 (예: Supabase Direct Session URL)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# 2. Supabase 클라이언트 연결 설정 (필수)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsIn..."

# 3. AI 모델링 & API 설정 (선택)
# 시맨틱 임베딩 및 대화 생성을 위한 OpenAI API Key
OPENAI_KEY=""
# 무료 Gemini API Key (Gemini 임베딩 및 Reflection 분석 보조용)
FREE_GEMINI_EMBEDDING_KEY=""
# AI 에이전트 세션 보안용 32바이트 16진수 암호 키
AI_ENCRYPTION_KEY="32-byte-hexadecimal-encryption-key-here"

# 4. 부가 서비스 설정 (선택)
# 이메일 전송 서비스를 위한 Resend API Key
RESEND_API_KEY=""

# 5. 프로덕션 및 모니터링 설정 (선택)
# 구글 애널리틱스 4 (GA4) 측정 ID (예: G-XXXXXXXXXX)
# 주입 시 베타 사이트에서 자동으로 수집이 기동되며, 비워두면 애널리틱스 수집이 차단됩니다.
NEXT_PUBLIC_GA_ID=""

# 표준 Canonical URL 및 검색엔진 로봇 분기용 배포 도메인 주소 (기본값: https://pixelyf.com)
NEXT_PUBLIC_SITE_URL="https://pixelyf.com"

# 배포 환경 구분 (production | development)
# dev.pixelyf.com 등 개발/테스트 환경의 경우 'development'로 설정하여 검색엔진 노출을 막습니다.
NEXT_PUBLIC_APP_ENV="production"
