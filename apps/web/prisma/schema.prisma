// ══════════════════════════════════════════════════════════════
// 생각그래프 (ThoughtGraph) 모델
// ══════════════════════════════════════════════════════════════

/// [생각그래프] 생각과 생각 간의 시맨틱 연결 (지식 그래프 엣지)
model MomentRelationship {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_moment_id String   @db.Uuid
  target_moment_id String   @db.Uuid

  /// 엣지 관계 유형: extends | supports | contradicts | refines | instantiates | requires | triggered-by | near-miss
  relation_type    String   @db.VarChar(30)

  /// 생성 주체: 'ai' (AI 1-hop 자동 연결) | 'user' (유저 수동 매핑) | 'ai-backfill' (AI 2-hop 백필 배치)
  created_by       String   @default("ai") @db.VarChar(15)

  /// 연결 상태: 'confirmed' (승인/자동승인) | 'pending' (토스트 대기) | 'rejected' (유저 거부 → 재추론 방지)
  status           String   @default("confirmed") @db.VarChar(10)

  /// 연결 강도 (0.0~1.0) — AI 추론 confidence 또는 유저 상호작용 기반
  weight           Float    @default(0.5) @db.Real

  /// 강화 횟수 — 다른 유저가 동일 관계를 확인(검증)할 때 +1
  reinforce_count  Int      @default(1)

  /// 마지막 활성화 시각 — 시간 감쇠(Recency Decay) 계산용
  last_access      DateTime @default(now()) @db.Timestamptz(6)

  created_at       DateTime @default(now()) @db.Timestamptz(6)

  source_moment    Moment   @relation("SourceRelationships", fields: [source_moment_id], references: [id], onDelete: Cascade)
  target_moment    Moment   @relation("TargetRelationships", fields: [target_moment_id], references: [id], onDelete: Cascade)

  @@unique([source_moment_id, target_moment_id, relation_type])
  @@index([source_moment_id])
  @@index([target_moment_id])
  @@index([status])
  /// [성능] Edge-First 쿼리 커버링 인덱스 — status 필터 + source/target JOIN 최적화
  @@index([status, source_moment_id, target_moment_id], map: "idx_moment_rel_status_edges")
  @@map("moment_relationships")
}

model StoreDetail {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @unique @db.Uuid
  phone            String?  // 매장 전화번호
  address          String?  // 도로명/지번 주소
  google_place_id  String?  // 구글맵 연동 위치 정보 (Place ID)
  latitude         Float?   // 실제 구글맵 위도 (좌표)
  longitude        Float?   // 실제 구글맵 경도 (좌표)
  business_hours   Json?    // 영업시간 (요일별 오픈/마감 시간, 브레이크타임, 휴일 정보 등 구조화된 JSON)
  menu_info        Json?    // 메뉴정보 (메뉴 이름, 가격, 상세설명, 메뉴 이미지 URL 등 구조화된 JSON)
  gallery_photos   String[] @default([]) // 매장 전경, 음식, 인테리어 등 갤러리 이미지 URL 배열
  description      String?  // 매장 상세 소개글 (장문)
  /// [09-플랜] 리뷰 집계 캐싱 — 매 렌더링 루프 DB 집계 방지
  /// average_rating = 배치(batch_reposition.py)에서 계산한 베이지안 평활화 최종값 저장 (단일 진실 공급원)
  review_count     Int      @default(0)
  average_rating   Float    @default(4.0)  // 기본값 = 플랫폼 평균 4.0 (리뷰 없는 신규 매장)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("store_details")
}

/// [K-Connect v4.0] 유저 관심 카테고리 + 한국 문화 이해도 프로필
model CulturalValueProfile {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid

  // 8대 카테고리 관심사
  /// 주 관심 카테고리 (ENTER|LANGUAGE|CULTURE|TRAVEL|FOOD|BRAND|LIFE|BUSINESS)
  primaryCategory     String?  @map("primary_category")
  /// 복수 관심 카테고리
  interestCategories  String[] @map("interest_categories") @default([])
  /// 세부 관심 태그
  interestTags        String[] @map("interest_tags") @default([])

  // 한국 문화 이해도 (글로벌 유저 전용)
  /// NONE | BASIC | INTERMEDIATE | FLUENT
  koreanLangLevel     String?  @map("korean_lang_level")
  /// ONLINE_ONLY | VISITED | LIVED | RESIDENT
  koreanExpLevel      String?  @map("korean_exp_level")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("cultural_value_profiles")
}


/// [K-Connect v4.0] 유저 간 카테고리 기반 Value Link 매칭 기록
model ValueLinkConnection {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAId          String   @map("user_a_id") @db.Uuid
  userBId          String   @map("user_b_id") @db.Uuid
  matchScore       Int      @map("match_score") @db.SmallInt // 0-100
  matchReasons     String[] @map("match_reasons") @default([])
  /// 공통 관심 카테고리 (핵심 매칭 근거)
  sharedCategories String[] @map("shared_categories") @default([])
  /// PENDING | ACTIVE | CONNECTED
  status           String   @default("PENDING")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  userA            User     @relation("LinkA", fields: [userAId], references: [id], onDelete: Cascade)
  userB            User     @relation("LinkB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("value_link_connections")
}
