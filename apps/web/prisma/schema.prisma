generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "partialIndexes"]
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserRole {
  USER
  CONTENT_ADMIN
  SUPER_ADMIN
}

enum NotificationType {
  TOUCH        // 누군가 나를 터치함
  PING         // 핑 수신
  COMMENT      // 모먼트 댓글
  BOND         // 별자리 연결 수락
  SYSTEM       // 시스템 공지
  SUBSCRIPTION // 생각 구독 관련
  DM           // DM 수신
}

model User {
  id                                                               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  google_uid                                                       String                  @unique
  pixel_id                                                         String                  @unique
  display_name                                                     String
  role                                                             UserRole                @default(USER)
  admin_profile                                                    AdminProfile?
  avatar_type                                                      String                  @default("svg")
  avatar_svg_id                                                    String?
  avatar_image_url                                                 String?
  current_aura                                                     String                  @default("GLOW")
  activity_score                                                   BigInt                  @default(0)
  streak_days                                                      Int                     @default(0)
  is_shadow_banned                                                 Boolean                 @default(false)
  shadow_ban_reason                                                String?
  status_message                                                   String?
  is_active                                                        Boolean                 @default(true)
  last_seen_at                                                     DateTime?               @db.Timestamptz(6)
  created_at                                                       DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                                                       DateTime                @default(now()) @db.Timestamptz(6)
  stardust_balance                                                 Int                     @default(0)
  supernova_tier                                                   String?
  supernova_expires_at                                             DateTime?               @db.Timestamptz(6)
  equipped_title                                                   String?
  space_id_stage                                                   Int                     @default(1)
  country                                                          String                  @default("KR")
  language                                                         String                  @default("ko")
  current_mood_id                                                  String?
  galaxy_activity_scores                                           Json?                   @default("{}")
  /// 별자리 연결 최대 수 (기본 10, 유료 서비스로 증가 가능)
  max_constellation_bonds                                          Int                     @default(20)
  /// AI 은하 활성화 여부
  ai_enabled                                                       Boolean                 @default(false)
  /// 대화용 기본 프로바이더 (gemini / openai / anthropic)
  ai_primary_provider                                              String?
  /// 대화용 기본 모델 (gemini-3.1-flash-lite 등)
  ai_primary_model                                                 String?
  /// 압축/Reflection용 모델 (gemini-3.1-flash-lite 등)
  ai_compaction_model                                              String?
  ai_interactions                                                  AiInteraction[]
  constellation_bonds_constellation_bonds_user_a_idTousers         constellation_bonds[]   @relation("constellation_bonds_user_a_idTousers")
  constellation_bonds_constellation_bonds_user_b_idTousers         constellation_bonds[]   @relation("constellation_bonds_user_b_idTousers")
  momentComments                                                   MomentComment[]
  moments                                                          Moment[]
  nebula_members                                                   nebula_members[]
  nebulae                                                          nebulae[]
  onboarding_answers                                               onboarding_answers[]
  pings_received                                                   Ping[]                  @relation("ReceivedPings")
  pings_sent                                                       Ping[]                  @relation("SentPings")
  visits_received                                                  PixelVisitLog[]         @relation("VisitsReceived")
  visits_made                                                      PixelVisitLog[]         @relation("VisitsMade")
  stardust_transactions                                            stardust_transactions[]
  thought_subscriptions_thought_subscriptions_creator_idTousers    thought_subscriptions[] @relation("thought_subscriptions_creator_idTousers")
  thought_subscriptions_thought_subscriptions_subscriber_idTousers thought_subscriptions[] @relation("thought_subscriptions_subscriber_idTousers")
  touches_touches_touched_idTousers                                touches[]               @relation("touches_touched_idTousers")
  touches_touches_toucher_idTousers                                touches[]               @relation("touches_toucher_idTousers")
  ai_affinities                                                    UserAiAffinity[]
  ai_provider_keys                                                 AiProviderKey[]
  ai_soul                                                          AiSoul?
  avatar_config                                                    user_avatar_config?
  user_blocks_user_blocks_blocked_idTousers                        user_blocks[]           @relation("user_blocks_blocked_idTousers")
  user_blocks_user_blocks_blocker_idTousers                        user_blocks[]           @relation("user_blocks_blocker_idTousers")
  coordinates                                                      UserCoordinate[]
  user_inventory                                                   user_inventory[]
  persona                                                          UserPersona?
  user_reports_user_reports_reported_idTousers                     user_reports[]          @relation("user_reports_reported_idTousers")
  user_reports_user_reports_reporter_idTousers                     user_reports[]          @relation("user_reports_reporter_idTousers")
  statistics                                                       UserStatistics[]
  translations                                                     UserProfileTranslation[]
  weekly_diaries                                                   weekly_diaries[]
  culturalValueProfile                                             CulturalValueProfile?
  valueLinkConnectionsA                                            ValueLinkConnection[]   @relation("LinkA")
  valueLinkConnectionsB                                            ValueLinkConnection[]   @relation("LinkB")
  /// Expo Push Token (모바일 앱 푸시 알림용)
  expo_push_token                                                  String?
  /// 세분화된 푸시 설정
  push_touch_enabled                                               Boolean                 @default(true)
  push_ping_enabled                                                Boolean                 @default(true)
  push_comment_enabled                                             Boolean                 @default(true)
  push_bond_enabled                                                Boolean                 @default(true)
  push_marketing_enabled                                           Boolean                 @default(false)
  push_subscription_enabled                                        Boolean                 @default(true)
  push_dm_enabled                                                  Boolean                 @default(true)
  /// Babel Feed: 피드 번역 대상 언어 코드 배열 (기본: 빈 배열 = 번역 안 함)
  feed_translation_languages                                       String[]                @default([])
  /// [09-플랜] 제휴 매장 픽셀 여부 (true = 매장, false = 일반 유저)
  /// 매장 등록(StoreDetail 생성) 시 true, 해제 시 false로 토글
  is_store                                                         Boolean                 @default(false)

  notifications Notification[]
  aiWhispers    AiWhisper[]
  store_reviews Moment[]       @relation("StoreReviews")
  store_detail  StoreDetail?

  // DM 관련
  dmParticipants  DmParticipant[]
  dmMessages      DmMessage[]
  createdDmGroups DmRoom[]        @relation("GroupCreator")

  mood_history    UserMoodHistory[]
  toneProfile     UserToneProfile?

  @@index([current_aura], map: "idx_users_current_aura")
  @@index([google_uid], map: "idx_users_google_uid")
  @@index([is_active], map: "idx_users_is_active", where: raw("(is_active = true)"))
  @@index([pixel_id], map: "idx_users_pixel_id")
  @@map("users")
}

model UserCoordinate {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  coordX            Float     @default(0) @map("coord_x")
  coordY            Float     @default(0) @map("coord_y")
  zDepth            Float     @default(1.0) @map("z_depth") @db.Real
  glowRadius        Float     @default(1.0) @map("glow_radius") @db.Real
  nebulaId          String?   @map("nebula_id") @db.Uuid
  isInBlackhole     Boolean   @default(false) @map("is_in_blackhole")
  lastStaticUpdate  DateTime  @default(now()) @map("last_static_update") @db.Timestamptz(6)
  lastDynamicUpdate DateTime? @map("last_dynamic_update") @db.Timestamptz(6)
  staticVector      Float[]   @map("static_vector") @db.Real
  dynamicVector     Float[]   @map("dynamic_vector") @db.Real
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  color             String?
  label             String?
  syncScore         Int?      @default(0) @map("sync_score") @db.SmallInt
  partnerCode       String?   @map("partner_code")
  galaxyKey         String?   @map("galaxy_key")

  // Multi-Persona (Phase 4): 은하별 커스텀 프로필
  display_name     String?
  avatar_image_url String?
  avatar_type      String  @default("image")
  activity_score   BigInt  @default(0)
  status_message   String?

  /// [진화] 일간 배치에서 계산된 활동량 기반 순위 (1 = 은하 챔피언)
  rank             Int?

  nebulae nebulae? @relation(fields: [nebulaId], references: [id], onUpdate: NoAction)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, galaxyKey], map: "idx_coords_user_galaxy", where: raw("(galaxy_key IS NOT NULL)"))
  @@index([partnerCode, galaxyKey], map: "idx_coords_partner_galaxy")
  @@index([nebulaId], map: "idx_coords_nebula_id")
  @@index([coordX, coordY], map: "idx_coords_position")
  @@map("user_coordinates")
}

model UserPersona {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String   @unique @db.Uuid
  score_e_i            Int      @default(50) @db.SmallInt
  score_s_n            Int      @default(50) @db.SmallInt
  score_t_f            Int      @default(50) @db.SmallInt
  score_j_p            Int      @default(50) @db.SmallInt
  score_morning_night  Int      @default(50) @db.SmallInt
  score_home_open      Int      @default(50) @db.SmallInt
  score_spend_save     Int      @default(50) @db.SmallInt
  score_depth_broad    Int      @default(50) @db.SmallInt
  score_calm_vibrant   Int      @default(50) @db.SmallInt
  score_yolo_future    Int      @default(50) @db.SmallInt
  persona_code         String   @default("INFP")
  persona_name         String
  persona_color        String
  glow_color_primary   String
  glow_color_secondary String
  survey_completed     Boolean  @default(false)
  survey_stage         Int      @default(0) @db.SmallInt
  /// [뉴런] 직업 카테고리 (15개 중 1개)
  occupation           String?
  /// [뉴런] 관심사 태그 (3~5개)
  interest_tags        String[]  @default([])
  /// [v4] 현재 생애 주기 단계
  life_stage           String?   @default("EARLY_CAREER")
  /// [v4] 생애 주기 전환 시작일
  life_stage_since     DateTime? @default(now()) @map("life_stage_since") @db.Timestamptz(6)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_personas")
}

/// [v3] 사용자 말투 프로파일 — LLM이 자동 분석한 결과 저장
model UserToneProfile {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String   @unique @db.Uuid
  /// 종결 패턴: "~해체", "~요체", "~ㅋㅋ" 등
  ending_style             String   @default("~해체")
  /// 평균 문장 길이 (글자 수)
  avg_sentence_length      Int      @default(20) @db.SmallInt
  /// 이모지 사용 빈도: none / low / moderate / high
  emoji_density            String   @default("low")
  /// 신조어/약어 사용 빈도: none / low / moderate / high
  slang_usage              String   @default("low")
  /// 격식 수준 (1=매우 캐주얼, 5=매우 격식)
  formality_level          Int      @default(2) @db.SmallInt
  /// 감정 표현 수준: restrained / moderate / rich
  emotional_expressiveness String   @default("moderate")
  /// LLM이 분석한 말투 특별 지시 (자유 텍스트)
  tone_instruction         String?  @db.Text
  /// 주인의 실제 글 예시 (Few-Shot용, 2~3개)
  writing_examples         String[] @default([])
  /// 마지막 분석 시각
  analyzed_at              DateTime @default(now()) @db.Timestamptz(6)
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_tone_profiles")
}

model Moment {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String             @db.Uuid
  content             String?
  image_url           String?
  aura_at_post        String
  category            String?
  galaxy_key          String?            @map("galaxy_key")
  topic_tags          String[]
  sentiment_vector    Float[]            @db.Real
  sentiment_label     String?
  ai_processed        Boolean            @default(false)
  ping_count          Int                @default(0)
  is_filtered         Boolean            @default(false)
  filter_reason       String?
  is_deleted          Boolean            @default(false)
  deleted_at          DateTime?          @db.Timestamptz(6)
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  images              Json?
  youtube_url         String?            @map("youtube_url")
  mood_id             String?
  comment_count       Int                @default(0)
  /// [생각 구독] 구독자 전용 콘텐츠 여부 (true = 구독자만 전문 열람 가능)
  is_subscriber_only  Boolean            @default(false) @map("is_subscriber_only")
  /// Babel Feed: 원문 언어 코드 (ko, en, ja 등)
  original_language   String?            @map("original_language")
  cosmic_weather_logs CosmicWeatherLog[]
  moment_comments     MomentComment[]
  translations        MomentTranslation[]
  user                User               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  target_pixel_id     String?            @db.Uuid
  target_pixel        User?              @relation("StoreReviews", fields: [target_pixel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pings               Ping[]
  user_reports        user_reports[]
  /// [K-Connect v4.0] 컨텐츠 카테고리 (ENTER|LANGUAGE|CULTURE|TRAVEL|FOOD|BRAND|LIFE|BUSINESS)
  contentCategory     String?            @map("content_category")
  /// [K-Connect v4.0] 세부 태그 배열
  contentTags         String[]           @map("content_tags") @default([])

  /// [생각그래프] 768차원 시맨틱 임베딩 (Matryoshka text-embedding-3-small / gemini-embedding-001)
  embedding           Unsupported("vector(768)")?
  /// [생각그래프] AI 자동 생성 요약 제목 (15자 내외)
  summary             String?            @db.VarChar(100)

  // [생각그래프] 관계 역참조
  sourceRelationships MomentRelationship[] @relation("SourceRelationships")
  targetRelationships MomentRelationship[] @relation("TargetRelationships")

  @@index([ai_processed], map: "idx_moments_ai_queue", where: raw("(ai_processed = false)"))
  @@index([category], map: "idx_moments_category", where: raw("(category IS NOT NULL)"))
  @@index([created_at(sort: Desc)], map: "idx_moments_created_at")
  @@index([user_id], map: "idx_moments_user_id")
  @@index([galaxy_key], map: "idx_moments_galaxy_key")
  @@map("moments")
}

/// Babel Feed: 피드 다국어 번역 저장 테이블
model MomentTranslation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moment_id   String   @db.Uuid
  /// ISO 639-1 언어 코드 (ja, en, zh, fr, es, de, pt, it)
  locale      String   @db.VarChar(5)
  /// 해당 언어 네이티브 생성 콘텐츠
  content     String   @db.Text
  /// 번역 상태: pending → completed → failed
  status      String   @default("pending")
  /// 사용된 토큰 수
  tokens_used Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  moment      Moment   @relation(fields: [moment_id], references: [id], onDelete: Cascade)

  @@unique([moment_id, locale])
  @@index([moment_id, locale])
  @@map("moment_translations")
}

model MomentComment {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moment_id  String          @db.Uuid
  user_id    String          @db.Uuid
  content    String          @db.VarChar(500)
  parent_id  String?         @db.Uuid
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  is_deleted Boolean         @default(false)
  moment     Moment          @relation(fields: [moment_id], references: [id], onDelete: Cascade)
  parent     MomentComment?  @relation("CommentToComment", fields: [parent_id], references: [id])
  replies    MomentComment[] @relation("CommentToComment")
  user       User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  translations MomentCommentTranslation[]

  @@index([moment_id, created_at])
  @@index([user_id])
  @@map("moment_comments")
}

model Ping {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  moment_id   String?  @db.Uuid
  galaxy_key  String?  @map("galaxy_key")
  ping_type   String
  is_crystal  Boolean  @default(false)
  is_filtered Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  moment      Moment?  @relation(fields: [moment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  receiver    User     @relation("ReceivedPings", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender      User     @relation("SentPings", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sender_id, receiver_id, created_at(sort: Desc)], map: "idx_pings_sender_receiver_created")
  @@index([receiver_id, created_at(sort: Desc)], map: "idx_pings_receiver_created")
  @@index([galaxy_key], map: "idx_pings_galaxy_key")
  @@map("pings")
}

model AiInteraction {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @db.Uuid
  character_code    String
  trigger_type      String
  action_type       String
  message           String?
  prompt_tokens     Int?
  completion_tokens Int?
  model_used        String?
  status            String    @default("pending")
  processed_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([processed_at])
  @@map("ai_interactions")
}

model UserAiAffinity {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String   @db.Uuid
  character_code     String
  affinity_score     Int      @default(0)
  resonance_stage    Int      @default(1)
  interaction_count  Int      @default(0)
  unlocked_skills    String[]
  last_interacted_at DateTime @default(now()) @db.Timestamptz(6)
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, character_code])
  @@map("user_ai_affinity")
}

model CosmicWeatherLog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  weather_type        String
  start_time          DateTime @db.Timestamptz(6)
  end_time            DateTime @db.Timestamptz(6)
  target_moment_id    String?  @db.Uuid
  stardust_multiplier Float    @default(1.0) @db.Real
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  moments             Moment?  @relation(fields: [target_moment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("cosmic_weather_logs")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model constellation_bonds {
  id                                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_a_id                                  String    @db.Uuid
  user_b_id                                  String    @db.Uuid
  bond_type                                  String    @default("\"constellation\"")
  bond_color                                 String?
  bond_shader                                String?
  created_at                                 DateTime  @default(now()) @db.Timestamptz(6)
  /// 연결 상태: 'pending'(승인 대기) | 'accepted'(연결 완료) | 'rejected'(거절됨)
  /// 기존 데이터는 마이그레이션 시 'accepted'로 backfill됨
  status                                     String    @default("accepted")
  /// 거절 시각 기록 — 30일 쿨다운 계산 기준 (rejected 상태일 때만 설정)
  rejected_at                                DateTime? @db.Timestamptz(6)
  /// [GALAXY INDEPENDENT] 연결이 발생한 은하 키 — 은하를 초월한 연결은 불가
  galaxy_key                                 String?   @map("galaxy_key")
  users_constellation_bonds_user_a_idTousers User      @relation("constellation_bonds_user_a_idTousers", fields: [user_a_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_constellation_bonds_user_b_idTousers User      @relation("constellation_bonds_user_b_idTousers", fields: [user_b_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_a_id, user_b_id, galaxy_key], map: "uq_constellation_bonds_a_b_galaxy")
  @@index([galaxy_key], map: "idx_constellation_bonds_galaxy_key")
}

model items {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  item_code         String           @unique
  item_type         String
  name              String
  description       String?
  price_star_dust   Int?
  is_limited        Boolean          @default(false)
  expires_at        DateTime?        @db.Timestamptz(6)
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  /// Spine 2D 에셋 경로 (Supabase Storage 버킷 내 상대경로)
  spine_asset_path  String?
  /// 아이템 미리보기 이미지 URL (카탈로그/상점 표시용)
  preview_image_url String?
  /// 아이템 슬롯 카테고리 (character_base, hair, top, bottom, accessory, effect)
  slot_category     String?
  /// 아이템 등급 (common, rare, epic, legendary)
  rarity            String           @default("common")
  user_inventory    user_inventory[]
}

/// 유저의 현재 아바타 장착 설정 (Modular Spine Skin)
